---

<header class="mb-8 sm:pt-8 md:col-start-1 md:row-start-1">
  <a
    href="/"
    class="block text-center transition-opacity hover:opacity-70 dark:hover:opacity-85"
  >
    <img
      src="/logo-bg.jpg"
      alt="Reda Lemeden"
      class="mask-sakigake mx-auto w-32"
    />
    <h1 class="text-l pb-1 font-bold tracking-[.18em] uppercase">
      Reda Lemeden
    </h1>
    <p
      class="px-8 text-xs tracking-wide text-stone-400 italic dark:text-[var(--muted-text)]"
    >
      <span id="subtitle"></span>
      <noscript>Indie Software Developer</noscript>
    </p>
  </a>
</header>

<script>
  const subtitles = [
    "Software Developer",
    "Pixel Counter",
    "Gamer Dad",
    "Prompt Mage",
    "Lifelong Learner",
    "開発の何でも屋",
  ];

  const subtitleElement = document.getElementById("subtitle");

  if (subtitleElement) {
    // Get two different random subtitles
    const firstIndex = Math.floor(Math.random() * subtitles.length);
    let secondIndex = Math.floor(Math.random() * subtitles.length);

    // Ensure we don't pick the same subtitle twice
    while (secondIndex === firstIndex) {
      secondIndex = Math.floor(Math.random() * subtitles.length);
    }

    subtitleElement.textContent = `${subtitles[firstIndex]} & ${subtitles[secondIndex]}`;
  }
</script>

<style>
  .mask-sakigake {
    mask-image: url("/logomark.svg");
    mask-repeat: no-repeat;
  }
</style>
