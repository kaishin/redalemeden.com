---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  name: string;
  image: string;
  year: string;
  state: string;
  url: string;
  description: string;
}

const { name, image, year, url, description } = Astro.props;

const imagePath = "/src/assets/images/projects/" + image;
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/projects/*.{jpeg,jpg,png,gif}",
);
if (!images[imagePath]) throw new Error(`Image ${imagePath} not found`);
const imageSrc = images[imagePath]();
---

<article
  class="overflow-hidden rounded-2xl bg-white shadow transition-all duration-300 ease-linear hover:scale-[1.03] dark:bg-[var(--surface-muted)] dark:shadow-[0_26px_80px_color-mix(in_oklab,var(--color-amethyst)_10%,transparent)] dark:ring-1 dark:ring-[var(--border-soft)]"
>
  <a href={url}>
    <Image src={imageSrc} class="max-w-full" alt={name} />

    <div class="p-6">
      <h5
        class="mx-0 mt-0 mb-2 text-sm font-semibold tracking-widest uppercase"
      >
        {name}
        <span class="text-stone-500 dark:text-[var(--muted-text)]"
          >({year})</span
        >
      </h5>
      <p
        class="text-sm font-light tracking-wider text-stone-500 dark:text-[var(--soft-text)]"
      >
        {description}
      </p>
    </div>
  </a>
</article>
