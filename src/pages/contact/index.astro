---
import NavigationLayout from "@layouts/NavigationLayout.astro";
---

<NavigationLayout>
  <h2>Get in Touch</h2>
  <p>
    Do you have some feedback or just want to say hi? If you're a human email me
    at hello@ and the website domain. If you're a robot, use the form below to
    "get in touch". I will do my best to reply within a reasonable timeframe.
  </p>
  <form name="contact">
    <input type="hidden" name="form-name" value="contact" />
    <fieldset>
      <label class="mb-2 block">
        <input
          class="focus:border-amethyst w-full appearance-none rounded-xl border border-stone-200/80 bg-white px-3 py-2 text-base text-stone-900 shadow-sm transition-colors placeholder:text-stone-300 focus:outline-none dark:border-[var(--border-soft)] dark:bg-[var(--input-bg)] dark:text-[var(--input-text)] dark:placeholder:text-[var(--input-placeholder)] dark:focus:border-[var(--accent-ui)]"
          placeholder="Your Name"
          type="text"
          name="name"
          required
        />
      </label>
      <label class="mb-2 block">
        <input
          class="focus:border-amethyst w-full appearance-none rounded-xl border border-stone-200/80 bg-white px-3 py-2 text-base text-stone-900 shadow-sm transition-colors placeholder:text-stone-300 focus:outline-none dark:border-[var(--border-soft)] dark:bg-[var(--input-bg)] dark:text-[var(--input-text)] dark:placeholder:text-[var(--input-placeholder)] dark:focus:border-[var(--accent-ui)]"
          placeholder="Your Email"
          type="email"
          name="email"
          required="true"
        />
      </label>
      <label class="mb-2 block">
        <textarea
          class="focus:border-amethyst h-40 w-full appearance-none rounded-xl border border-stone-200/80 bg-white px-3 py-2 text-base text-stone-900 shadow-sm transition-colors placeholder:text-stone-300 focus:outline-none dark:border-[var(--border-soft)] dark:bg-[var(--input-bg)] dark:text-[var(--input-text)] dark:placeholder:text-[var(--input-placeholder)] dark:focus:border-[var(--accent-ui)]"
          placeholder="Your Message..."
          name="message"
          id="message"
          required="true"></textarea>
      </label>
    </fieldset>
    <button
      type="submit"
      class="bg-amethyst rounded-3xl px-6 py-2 text-white transition duration-150 ease-in-out hover:bg-[var(--accent-ui-hover)] active:scale-95 dark:bg-[var(--accent-ui)] dark:text-[var(--color-nightshade)] dark:hover:bg-[var(--accent-ui-hover)]"
      >Send</button
    >
  </form>
</NavigationLayout>
