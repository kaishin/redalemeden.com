---
import NavigationLayout from "@layouts/NavigationLayout.astro";
---

<NavigationLayout>
  <h2>Get in Touch</h2>
  <p>
    Do you have some feedback or just want to say hi? Use the form below to get
    in touch. I will do my best to reply within a reasonable timeframe.
  </p>

  <p
    class="rounded-2xl border border-stone-200 bg-white/70 px-4 py-3 dark:border-[var(--border-soft)] dark:bg-[var(--surface-soft)] dark:text-[var(--soft-text)]"
  >
    ✅ Message successfully sent. Thank you for getting in touch!
  </p>
</NavigationLayout>
